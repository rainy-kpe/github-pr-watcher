# GitHub personal access token (classic or fine-grained)
# Required scopes for private repos: Pull requests (read), Issues (read), Metadata (read)
GITHUB_TOKEN=ghp_your_token_here

# Optional alias for classic PATs (used if GITHUB_TOKEN is empty)
GITHUB_CLASSIC_TOKEN=

# Optional: Custom GitHub API base URL (for GitHub Enterprise Server)
# Example: https://github.your-company.com/api/v3
GITHUB_API_BASE_URL=

# Comma-separated list of repositories in owner/repo format
REPOSITORIES=octocat/Hello-World,microsoft/vscode

# Polling frequency in seconds
POLL_INTERVAL_SECONDS=60

# Where local watcher state is saved
STATE_FILE=./state/watcher-state.json

# Set to true to trigger notifications for already-existing events on first run
NOTIFY_ON_STARTUP=false

# Notification app name
APP_NAME=GitHub PR Watcher
