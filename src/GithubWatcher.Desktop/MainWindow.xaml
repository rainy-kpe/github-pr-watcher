<Window x:Class="GithubWatcher.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GithubWatcher.Desktop"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="GitHub Pull Requests"
        Width="400"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{DynamicResource PrimaryTextBrush}"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:MainWindow, IsDesignTimeCreatable=True}">
    <Border Margin="8"
            Background="{DynamicResource SurfaceBrush}"
            CornerRadius="8"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1">
        <Grid Margin="8">
            <ListBox x:Name="PrList"
                      Background="{DynamicResource SurfaceBrush}"
                     BorderThickness="0"
                     Padding="0"
                      Foreground="{DynamicResource PrimaryTextBrush}"
                      Width="360"
                      HorizontalAlignment="Left"
                     HorizontalContentAlignment="Stretch"
                     ItemsSource="{Binding PullRequests}"
                     SelectionChanged="PrList_SelectionChanged"
                     ScrollViewer.CanContentScroll="False"
                     ScrollViewer.VerticalScrollBarVisibility="Hidden">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="BorderThickness" Value="0" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0" ClipToBounds="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="282" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Margin="4,6,8,6" HorizontalAlignment="Stretch">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="{Binding Title}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="1" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,2,0,0">
                                    <Run Text="{Binding RepositoryName, Mode=OneWay}" />
                                    <Run Text=" - " />
                                    <Run Text="{Binding Author}" />
                                </TextBlock>
                            </Grid>

                            <Border Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Width="68"
                                    CornerRadius="10"
                                    Padding="8,2"
                                    Background="{DynamicResource StatusBadgeBrush}"
                                    HorizontalAlignment="Right">
                                <TextBlock FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Waiting" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsApproved}" Value="True">
                                                    <Setter Property="Text" Value="Approved" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Text="There are no open PRs"
                       FontSize="14"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Opacity="0.8"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=PrList, Path=Items.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Border>
</Window>
