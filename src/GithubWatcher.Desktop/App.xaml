<Application x:Class="GithubWatcher.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FF202020" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FF1E1E1E" />
        <SolidColorBrush x:Key="WindowBorderBrush" Color="#FF2D2D30" />
        <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FF252525" />
        <SolidColorBrush x:Key="ControlBorderBrush" Color="#FF3A3A3A" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FFB0B0B0" />
        <SolidColorBrush x:Key="StatusBadgeBrush" Color="#FF2D2D30" />
    </Application.Resources>
</Application>
